{
  "name": "cleanplay-console",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "test": "vite build && vitest",
    "test:ci": "vite build && vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx,.mts",
    "lint:fix": "eslint . --ext .ts,.tsx,.mts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "audit": "bun audit",
    "fe:dev": "vite",
    "fe:serve": "vite preview",
    "be:dev": "bun --watch server.ts",
    "start": "bun server.ts",
    "build": "vite build",
    "dev": "concurrently \"bun run fe:dev\" \"bun run be:dev\"",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.3.2",
    "body-parser": "^1.20.1",
    "cookie-session": "^2.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "redis": "^4.6.4",
    "ua-parser-js": "^1.0.35"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^8.0.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "steamid": "^2.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^4.2.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
