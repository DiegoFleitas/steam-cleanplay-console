{
  "name": "cleanplay-console",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "fe:dev": "vite",
    "fe:serve": "vite preview",
    "be:dev": "nodemon -e ts -x tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "dev": "concurrently \"npm:fe:dev\" \"npm:be:dev\"",
    "app": "npx cross-var echo $npm_package_name",
    "fly:deploy": "flyctl deploy",
    "fly:logs": "npx cross-var flyctl logs -a $npm_package_name",
    "fly:stop": "npx cross-var flyctl scale count 0 -a $npm_package_name",
    "fly:start": "npx cross-var flyctl scale count 1 -a $npm_package_name",
    "fly:ssh": "npx cross-var flyctl ssh console -a $npm_package_name"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.3.2",
    "body-parser": "^1.20.1",
    "cookie-session": "^2.0.0",
    "diegos-fly-logger": "^1.0.1",
    "dotenv": "^16.0.3",
    "express": "^4.17.1",
    "morgan": "^1.10.0",
    "redis": "^4.6.4",
    "tsx": "^4.21.0",
    "ua-parser-js": "^1.0.35"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^8.0.1",
    "cross-var": "^1.1.0",
    "jsdom": "^24.1.3",
    "nodemon": "^3.1.14",
    "steamid": "^2.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^4.2.1",
    "vitest": "^2.1.9"
  }
}
