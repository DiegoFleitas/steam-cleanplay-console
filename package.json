{
  "name": "cleanplay-console",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "test": "vite build && vitest",
    "test:ci": "vite build && vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx,.mts",
    "lint:fix": "eslint . --ext .ts,.tsx,.mts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "audit": "bun audit",
    "fe:dev": "vite",
    "fe:serve": "vite preview",
    "be:dev": "bun --watch server.ts",
    "start": "bun server.ts",
    "build": "vite build",
    "dev": "concurrently \"bun run fe:dev\" \"bun run be:dev\"",
    "app": "bunx cross-var echo $npm_package_name",
    "fly:deploy": "flyctl deploy",
    "fly:logs": "bunx cross-var flyctl logs -a $npm_package_name",
    "fly:stop": "bunx cross-var flyctl scale count 0 -a $npm_package_name",
    "fly:start": "bunx cross-var flyctl scale count 1 -a $npm_package_name",
    "fly:ssh": "bunx cross-var flyctl ssh console -a $npm_package_name",
    "setup:hooks": "node ./node_modules/husky/bin.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "body-parser": "^2.2.2",
    "cookie-session": "^2.0.0",
    "diegos-fly-logger": "^2.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "morgan": "^1.10.0",
    "redis": "^5.12.1",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^9.2.1",
    "cross-var": "^1.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "steamid": "^2.0.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
